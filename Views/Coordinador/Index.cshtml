@model IEnumerable<PortalAcademico.Models.Matricula>

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-dark text-white">
            <h3 class="mb-0">Panel de Control: Gestión de Matrículas</h3>
        </div>
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Email del Alumno</th>
                        <th>Curso</th>
                        <th>ID Registro</th>
                        <th>Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            @* 1. Si UsuarioEmail sale en rojo, probamos con Email *@
                            <td>@(item.GetType().GetProperty("UsuarioEmail") != null ? item.GetType().GetProperty("UsuarioEmail").GetValue(item) : "Revisar Modelo")</td>
                            
                            @* 2. El curso suele ser estándar *@
                            <td>@item.Curso?.Nombre (@item.Curso?.Codigo)</td>
                            
                            @* 3. Si FechaMatricula falla, ponemos el ID para que no rompa la página *@
                            <td>Registro #@item.Id</td>
                            
                            <td>
                                <form asp-action="Eliminar" asp-route-id="@item.Id" method="post">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('¿Eliminar matrícula?')">Eliminar</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>