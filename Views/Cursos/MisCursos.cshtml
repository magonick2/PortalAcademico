@model IEnumerable<PortalAcademico.Models.Matricula>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Mis Cursos Inscritos</h2>
        <a asp-action="Index" class="btn btn-outline-primary">Volver al Catálogo</a>
    </div>

    <hr />

    @if (!Model.Any())
    {
        <div class="alert alert-info">Aún no te has inscrito en ningún curso.</div>
    }
    else
    {
        <div class="table-responsive mt-3">
            <table class="table table-hover border">
                <thead class="table-dark">
                    <tr>
                        <th>Código</th>
                        <th>Curso</th>
                        <th>Créditos</th>
                        <th>Fecha de Inscripción</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Curso?.Codigo</td>
                            <td>@item.Curso?.Nombre</td>
                            <td>@item.Curso?.Creditos</td>
                            <td>@item.FechaRegistro.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><span class="badge bg-success">@item.Estado</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    @if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>¡Logrado!</strong> @TempData["Mensaje"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
</div>